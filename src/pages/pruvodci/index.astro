---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StoryCard from '../../components/travel/StoryCard.astro';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('guides', ({ data }) => !data.draft);
const sorted = allGuides.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryLabels: Record<string, string> = {
  nabijecky: 'Nabíječky', planovani: 'Plánování', ubytovani: 'Ubytování',
  finance: 'Finance', technika: 'Technika', zimni: 'Zimní jízda', ostatni: 'Ostatní',
};
---

<BaseLayout
  title="Průvodci — praktické tipy pro EV cestování"
  description="Praktické průvodce pro cestování elektromobilem. Nabíjení, plánování tras, ubytování, finance a technika."
>
  <div class="page-wrap">
    <div class="container">
      <div class="page-header" data-reveal>
        <h1>Průvodci</h1>
        <p class="page-lead">Praktické rady pro cestování elektrickým autem.</p>
      </div>

      {sorted.length > 0 ? (
        <div class="guides-list">
          {sorted.map((guide, i) => (
            <a href={`/pruvodci/${guide.slug}/`} class="guide-row card" data-reveal style={`transition-delay: ${i * 0.05}s`}>
              <div class="guide-cat">
                <span class="cat-badge">{categoryLabels[guide.data.category] ?? guide.data.category}</span>
                {guide.data.difficulty && <span class="diff-badge diff-{guide.data.difficulty}">{guide.data.difficulty}</span>}
              </div>
              <div class="guide-info">
                <h2 class="guide-title">{guide.data.title}</h2>
                <p class="guide-desc">{guide.data.description}</p>
              </div>
              <div class="guide-meta">
                {guide.data.readingTime && <span>{guide.data.readingTime} min</span>}
                <span class="guide-arrow" aria-hidden="true">→</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty">Průvodci se připravují.</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap { padding-top: calc(72px + 3rem); padding-bottom: 5rem; }
  .page-header { margin-bottom: 2.5rem; }
  .page-lead { font-size: 1.1rem; color: var(--text-muted); margin-top: 0.5rem; }
  .guides-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .guide-row {
    display: grid; grid-template-columns: 140px 1fr auto;
    align-items: center; gap: 1.5rem;
    padding: 1.25rem 1.5rem; text-decoration: none;
    border-radius: var(--radius-lg);
  }
  @media (max-width: 640px) { .guide-row { grid-template-columns: 1fr; } }
  .cat-badge { font-family: var(--font-sans); font-size: 0.75rem; font-weight: 600; color: var(--sky-hover); background: var(--sky-light); padding: 0.25rem 0.65rem; border-radius: 100px; }
  .guide-title { font-size: 1.05rem; margin-bottom: 0.25rem; color: var(--text-heading); }
  .guide-desc { font-size: 0.875rem; color: var(--text-muted); margin: 0; max-width: none; }
  .guide-meta { display: flex; align-items: center; gap: 0.75rem; font-size: 0.82rem; color: var(--text-dim); font-family: var(--font-sans); white-space: nowrap; }
  .guide-arrow { font-size: 1.1rem; color: var(--accent); transition: transform var(--duration) var(--ease); }
  .guide-row:hover .guide-arrow { transform: translateX(4px); }
  .empty { color: var(--text-muted); padding: 3rem 0; }
</style>
