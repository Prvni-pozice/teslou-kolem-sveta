---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const galleries = await getCollection('galleries', ({ data }) => !data.draft);
  return galleries.map(gal => ({
    params: { slug: gal.slug },
    props: { gal },
  }));
}

const { gal } = Astro.props;
const { title, description, pubDate, photos, heroImage, heroImageAlt, expeditionName } = gal.data;
---

<BaseLayout title={title} description={description} ogImage={heroImage} type="article" pubDate={pubDate}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Domů",    "item": "https://www.tesloukolemsveta.cz/" },
      { "@type": "ListItem", "position": 2, "name": "Galerie", "item": "https://www.tesloukolemsveta.cz/galerie/" },
      { "@type": "ListItem", "position": 3, "name": title,     "item": Astro.url.href }
    ]
  })} />

  <div class="gal-wrap">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Domů</a><span aria-hidden="true">›</span>
        <a href="/galerie/">Galerie</a><span aria-hidden="true">›</span>
        <span aria-current="page">{title}</span>
      </nav>
      <h1>{title}</h1>
      {expeditionName && <p class="expedition-label">{expeditionName}</p>}
      <p class="gal-desc">{description}</p>

      {photos.length > 0 ? (
        <div class="photo-grid">
          {photos.map(photo => (
            <figure class="photo-item">
              <img
                src={photo.src}
                alt={photo.alt}
                loading="lazy"
                class="photo-img"
              />
              {photo.caption && (
                <figcaption class="photo-caption">
                  {photo.caption}
                  {photo.location && <span class="photo-location"> — {photo.location}</span>}
                </figcaption>
              )}
            </figure>
          ))}
        </div>
      ) : (
        <p class="empty">Fotografie se nahrávají.</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .gal-wrap { padding-top: calc(72px + 2.5rem); padding-bottom: 5rem; }
  .breadcrumb { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem; }
  .breadcrumb a { color: var(--text-muted); } .breadcrumb a:hover { color: var(--accent); }
  h1 { margin-bottom: 0.5rem; }
  .expedition-label { font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.5rem; }
  .gal-desc { color: var(--text-muted); font-size: 1.05rem; margin-bottom: 2.5rem; max-width: 60ch; }

  .photo-grid {
    columns: 1; gap: 1rem;
  }
  @media (min-width: 600px) { .photo-grid { columns: 2; } }
  @media (min-width: 900px) { .photo-grid { columns: 3; } }

  .photo-item { break-inside: avoid; margin-bottom: 1rem; }
  .photo-img { width: 100%; border-radius: var(--radius); display: block; }
  .photo-caption { font-size: 0.82rem; color: var(--text-muted); margin-top: 0.4rem; padding: 0 0.25rem; }
  .photo-location { color: var(--text-dim); }
  .empty { color: var(--text-muted); padding: 3rem 0; }
</style>
