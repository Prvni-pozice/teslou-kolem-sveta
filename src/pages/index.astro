---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import FeaturedStories from '../components/home/FeaturedStories.astro';
import ContinentsSection from '../components/home/ContinentsSection.astro';
import ContinentBest from '../components/home/ContinentBest.astro';
import CountriesTeaser from '../components/home/CountriesTeaser.astro';
import { getCollection } from 'astro:content';

const allStories = await getCollection('stories', ({ data }) => !data.draft);
const sortedStories = allStories.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Featured cesta articles for the top grid
const featuredJourney = sortedStories.filter(s => s.data.featured && s.data.category === 'cesta');
const latestStories = featuredJourney.length >= 3
  ? featuredJourney.slice(0, 6)
  : [...featuredJourney, ...sortedStories.filter(s => !s.data.featured && s.data.category === 'cesta')].slice(0, 6);

// Best article per continent (prefer featured cesta, fall back to any featured)
const continentDef = [
  { slug: 'asie',    nameCs: 'Asie',     color: '#e85d4a' },
  { slug: 'ameriky', nameCs: 'Ameriky',  color: '#2cb67d' },
  { slug: 'afrika',  nameCs: 'Afrika',   color: '#f5a623' },
  { slug: 'evropa',  nameCs: 'Evropa',   color: '#4f7ef7' },
];

const storiesByContinent = continentDef.map(c => {
  const pool = allStories.filter(s => s.data.continent === c.slug);
  const story =
    pool.find(s => s.data.featured && s.data.category === 'cesta') ??
    pool.find(s => s.data.featured) ??
    pool.find(s => s.data.heroImage) ??
    pool[0] ??
    null;
  return { ...c, story };
}).filter(c => c.story !== null);

const allContinents = await getCollection('continents', ({ data }) => !data.draft);
const sortedContinents = allContinents.sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const allCountries = await getCollection('countries');
const visitedCountries = allCountries.filter(c => c.data.visited);
---

<BaseLayout
  title="Teslou kolem světa — cestujeme elektrickým autem"
  description="194 dní, 40 700 km, 5 kontinentů. Blog o cestě elektrickým autem kolem celého světa. Příběhy, průvodci a videa z výprav Teslou."
>
  <!-- Schema: WebSite -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Teslou kolem světa",
    "url": "https://www.tesloukolemsveta.cz",
    "description": "194 dní, 40 700 km, 5 kontinentů — elektrickým autem kolem celého světa.",
    "inLanguage": "cs",
    "publisher": {
      "@type": "Organization",
      "name": "Teslou kolem světa",
      "url": "https://www.tesloukolemsveta.cz",
      "sameAs": [
        "https://youtube.com/@tesloukolemsveta",
        "https://www.facebook.com/share/18f92Ezd8K/"
      ]
    }
  })} />

  <Hero
    totalKm={40700}
    countriesCount={visitedCountries.length}
    storiesCount={allStories.length}
  />

  <FeaturedStories stories={latestStories} />

  <ContinentBest storiesByContinent={storiesByContinent} />

  <CountriesTeaser countries={allCountries} />

  <ContinentsSection continents={sortedContinents} />
</BaseLayout>
