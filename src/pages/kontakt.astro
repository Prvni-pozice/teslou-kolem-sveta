---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kontakt"
  description="Napište nám — spolupráce, otázky nebo jen sdílení vaší elektro-výpravy."
>
  <div class="page-wrap">
    <div class="container">
      <div class="page-header" data-reveal>
        <h1>Kontakt</h1>
        <p class="page-lead">Napište nám. Rádi si přečteme o vašich elektro-výpravách.</p>
      </div>

      <div class="contact-grid" data-reveal>
        <div class="contact-card">
          <h2>YouTube</h2>
          <p>Komentáře pod videi jsou nejrychlejší cesta.</p>
          <a href="https://youtube.com/@tesloukolemsveta" class="btn btn-primary" target="_blank" rel="noopener">
            Otevřít YouTube kanál
          </a>
        </div>
        <div class="contact-card">
          <h2>Facebook</h2>
          <p>Píšeme o výpravách i mezi videi.</p>
          <a href="https://www.facebook.com/tesloukolemsveta/" class="btn btn-outline" target="_blank" rel="noopener">
            Facebook stránka
          </a>
        </div>
        <div class="contact-card">
          <h2>Instagram</h2>
          <p>Fotky ze silnice, zákulisí a rychlé střihy z cest.</p>
          <a href="https://www.instagram.com/tesloukolemsveta/" class="btn btn-outline" target="_blank" rel="noopener">
            Instagram profil
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap { padding-top: calc(72px + 3rem); padding-bottom: 5rem; }
  .page-header { margin-bottom: 2.5rem; }
  .page-lead { font-size: 1.1rem; color: var(--text-muted); margin-top: 0.75rem; }
  .contact-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; max-width: 700px; }
  .contact-card {
    background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: 2rem; display: flex; flex-direction: column; gap: 0.75rem;
  }
  .contact-card h2 { font-size: 1.2rem; margin: 0; }
  .contact-card p { color: var(--text-muted); font-size: 0.95rem; margin: 0; max-width: none; }
</style>
