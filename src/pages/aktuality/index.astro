---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StoryCard from '../../components/travel/StoryCard.astro';
import { getCollection } from 'astro:content';

const allStories = await getCollection('stories', ({ data }) => !data.draft);
const aktuality = allStories
  .filter(s => s.data.category === 'aktualita')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Aktuality — novinky po návratu"
  description="Co se dělo po návratu z cesty kolem světa. Setkání s cestovateli, přednášky, události a novinky ze zákulisí výpravy."
>
  <div class="page-wrap">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Domů</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Aktuality</span>
      </nav>

      <div class="page-header" data-reveal>
        <h1>Aktuality</h1>
        <p class="page-lead">
          Co se dělo po návratu z cesty kolem světa — setkání s cestovateli,
          přednášky, události a novinky ze zákulisí výpravy.
        </p>
      </div>

      {aktuality.length > 0
        ? <div class="grid-3">{aktuality.map(story => <StoryCard story={story} />)}</div>
        : <p class="empty">Aktuality se připravují.</p>
      }
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap { padding-top: calc(72px + 3rem); padding-bottom: 5rem; }
  .breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb a:hover { color: var(--accent); }
  .page-header { margin-bottom: 2.5rem; }
  .page-lead { font-size: 1.1rem; color: var(--text-muted); margin-top: 0.5rem; max-width: 60ch; }
  .empty { color: var(--text-muted); padding: 3rem 0; }
</style>
