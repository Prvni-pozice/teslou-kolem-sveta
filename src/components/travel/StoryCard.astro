---
import Badge from '../ui/Badge.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  story: CollectionEntry<'stories'>;
  featured?: boolean;
}

const { story, featured = false } = Astro.props;
const { title, description, pubDate, category, tags, heroImage, heroImageAlt, readingTime, continent } = story.data;

const categoryLabels: Record<string, string> = {
  cesta: 'Cesta', pruvodce: 'Průvodce', technika: 'Technika', zamysleni: 'Zamyšlení',
};

const formattedDate = pubDate.toLocaleDateString('cs-CZ', {
  day: 'numeric', month: 'long', year: 'numeric',
});
---

<article class:list={['story-card card', { 'story-card--featured': featured }]}>
  <a href={`/pribehy/${story.slug}/`} class="card-link" tabindex="-1" aria-hidden="true">
    <div class="card-image-wrap">
      {heroImage
        ? <img class="card-img" src={heroImage} alt={heroImageAlt ?? title} loading="lazy" />
        : <div class="card-img card-img-placeholder" aria-hidden="true"></div>
      }
      <span class="card-badge">
        <Badge variant="sky">{categoryLabels[category] ?? category}</Badge>
      </span>
    </div>
  </a>

  <div class="card-body">
    <div class="card-meta">
      <time datetime={pubDate.toISOString()} class="card-date">{formattedDate}</time>
      {readingTime && <span class="card-reading">{readingTime} min</span>}
    </div>

    <h3 class="card-title">
      <a href={`/pribehy/${story.slug}/`}>{title}</a>
    </h3>

    <p class="card-desc">{description}</p>

    {tags.length > 0 && (
      <div class="card-tags">
        {tags.slice(0, 3).map(tag => <span class="card-tag">{tag}</span>)}
      </div>
    )}
  </div>
</article>

<style>
  .story-card {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .card-link {
    display: block;
    text-decoration: none;
  }

  .card-image-wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }

  .card-img {
    aspect-ratio: 16/9;
    width: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s var(--ease);
  }

  .card-img-placeholder {
    background: linear-gradient(135deg, var(--sky-light) 0%, var(--slate-100) 100%);
  }

  .story-card:hover .card-img {
    transform: scale(1.03);
  }

  .card-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
  }

  .card-body {
    flex: 1;
    padding: 1.25rem 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-dim);
    font-family: var(--font-sans);
  }

  .card-title {
    font-size: 1.05rem;
    line-height: 1.35;
    margin: 0;
  }

  .card-title a {
    color: var(--text-heading);
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }

  .card-title a::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .card-title a:hover { color: var(--accent); }

  .card-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-width: none;
    margin: 0;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.25rem;
  }

  .card-tag {
    font-size: 0.72rem;
    color: var(--text-dim);
    background: var(--slate-100);
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    font-family: var(--font-sans);
  }

  /* Featured variant */
  .story-card--featured .card-img {
    aspect-ratio: 4/3;
  }
</style>
