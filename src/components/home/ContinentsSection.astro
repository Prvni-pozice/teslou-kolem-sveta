---
import type { CollectionEntry } from 'astro:content';

interface Props {
  continents: CollectionEntry<'continents'>[];
}

const { continents } = Astro.props;

const continentColors: Record<string, string> = {
  evropa: 'var(--cont-europe)',
  asie: 'var(--cont-asia)',
  afrika: 'var(--cont-africa)',
  ameriky: 'var(--cont-americas)',
  oceanie: 'var(--cont-oceania)',
};
---

<section class="continents-section section" style="background: var(--bg-2);" aria-labelledby="continents-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="continents-heading">Kde jsme byli</h2>
      <p>Výpravy podle kontinentů</p>
    </div>

    <div class="continents-grid">
      {continents.map((cont, i) => (
        <a
          href={`/kontinenty/${cont.slug}/`}
          class="continent-card"
          data-reveal
          style={`transition-delay: ${i * 0.07}s; --cont-color: ${continentColors[cont.data.slug] ?? 'var(--accent)'}`}
        >
          {cont.data.heroImage && (
            <div class="cont-image-wrap">
              <img
                src={cont.data.heroImage}
                alt={cont.data.heroImageAlt ?? cont.data.nameCs}
                loading="lazy"
                class="cont-image"
              />
            </div>
          )}
          <div class="cont-body">
            <span class="cont-color-dot" aria-hidden="true"></span>
            <h3 class="cont-name">{cont.data.nameCs}</h3>
            {cont.data.countriesVisited > 0 && (
              <p class="cont-meta">{cont.data.countriesVisited} zemí · {cont.data.totalKm ? `${(cont.data.totalKm/1000).toFixed(0)} tis. km` : ''}</p>
            )}
            <span class="cont-arrow" aria-hidden="true">→</span>
          </div>
        </a>
      ))}

    </div>
  </div>
</section>

<style>
  .continents-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 220px), 1fr));
    gap: 1rem;
  }

  .continent-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    transition:
      box-shadow var(--duration) var(--ease),
      transform var(--duration) var(--ease),
      border-color var(--duration) var(--ease);
    display: flex;
    flex-direction: column;
  }

  .continent-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-color: var(--cont-color, var(--accent));
  }

  .continent-card--soon {
    border-style: dashed;
    opacity: 0.5;
    pointer-events: none;
  }

  .cont-image-wrap {
    height: 120px;
    overflow: hidden;
  }

  .cont-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s var(--ease);
  }

  .continent-card:hover .cont-image { transform: scale(1.06); }

  .cont-body {
    padding: 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
    position: relative;
  }

  .cont-color-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--cont-color, var(--accent));
    margin-bottom: 0.25rem;
  }

  .cont-name {
    font-size: 1.1rem;
    color: var(--text-heading);
    margin: 0;
  }

  .cont-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0;
    max-width: none;
  }

  .cont-arrow {
    position: absolute;
    bottom: 1.1rem;
    right: 1.25rem;
    color: var(--cont-color, var(--accent));
    font-size: 1rem;
    opacity: 0;
    transition: opacity var(--duration) var(--ease), transform var(--duration) var(--ease);
  }

  .continent-card:hover .cont-arrow {
    opacity: 1;
    transform: translateX(3px);
  }
</style>
