---
const year = new Date().getFullYear();

const links = {
  expedice: [
    { label: 'Všechny příběhy', href: '/pribehy/' },
    { label: 'Kontinenty', href: '/kontinenty/' },
    { label: 'Země', href: '/zeme/' },
    { label: 'Trasa / Timeline', href: '/trasa/' },
  ],
  prakticky: [
    { label: 'Průvodci', href: '/pruvodci/' },
    { label: 'Galerie', href: '/galerie/' },
    { label: 'Videa', href: '/videa/' },
  ],
  projekt: [
    { label: 'O projektu', href: '/o-projektu/' },
    { label: 'Kontakt', href: '/kontakt/' },
    { label: 'RSS feed', href: '/rss.xml' },
  ],
};
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Teslou kolem světa">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <circle cx="16" cy="16" r="14" stroke="var(--accent)" stroke-width="2"/>
            <path d="M4 16 Q16 8 28 16 Q16 24 4 16Z" fill="var(--accent)" opacity="0.3"/>
            <circle cx="16" cy="16" r="3" fill="var(--accent)"/>
          </svg>
          <span class="footer-logo-text">Teslou kolem světa</span>
        </a>
        <p class="footer-tagline">
          Cestujeme elektrickým autem. Dokumentujeme každý kilometr.
        </p>
        <div class="footer-social">
          <a
            href="https://youtube.com/@tesloukolemsveta"
            target="_blank"
            rel="noopener"
            aria-label="YouTube kanál Teslou kolem světa"
            class="social-link"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
          <a
            href="https://www.facebook.com/share/18f92Ezd8K/"
            target="_blank"
            rel="noopener"
            aria-label="Facebook stránka Teslou kolem světa"
            class="social-link"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav columns -->
      <div class="footer-col">
        <h3 class="footer-col-title">Expedice</h3>
        <ul>
          {links.expedice.map(l => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-col-title">Prakticky</h3>
        <ul>
          {links.prakticky.map(l => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-col-title">Projekt</h3>
        <ul>
          {links.projekt.map(l => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">© {year} Teslou kolem světa</p>
      <p class="footer-built">80edays · 2024</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--slate-900);
    color: var(--slate-300);
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; }
  }

  /* Brand */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .footer-logo-text {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.95rem;
    color: #fff;
  }

  .footer-tagline {
    font-size: 0.9rem;
    color: var(--slate-400);
    line-height: 1.6;
    max-width: 28ch;
    margin-bottom: 1.25rem;
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-sm);
    background: rgba(255,255,255,0.06);
    color: var(--slate-400);
    text-decoration: none;
    transition: background var(--duration) var(--ease), color var(--duration) var(--ease);
  }

  .social-link:hover {
    background: var(--accent);
    color: #fff;
  }

  /* Nav columns */
  .footer-col-title {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--slate-500);
    margin-bottom: 1rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col a {
    font-size: 0.9rem;
    color: var(--slate-400);
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }

  .footer-col a:hover { color: #fff; }

  /* Bottom */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding-top: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-copy, .footer-built {
    font-size: 0.82rem;
    color: var(--slate-500);
    max-width: none;
  }

  .footer-built a {
    color: var(--slate-400);
    text-decoration: none;
  }

  .footer-built a:hover { color: #fff; }
</style>
