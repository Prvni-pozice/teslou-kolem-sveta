---
import '../styles/fonts.css';
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  continent?: string;
  country?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage = '/og-default.jpg',
  canonicalURL = Astro.url.href,
  type = 'website',
  pubDate,
  continent,
  country,
  noindex = false,
} = Astro.props;

const siteUrl  = 'https://www.tesloukolemsveta.cz';
const siteName = 'Teslou kolem světa';
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const ogImageAbs = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!DOCTYPE html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type"        content={type} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImageAbs} />
    <meta property="og:locale"      content="cs_CZ" />
    <meta property="og:site_name"   content={siteName} />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageAbs} />

    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {continent && <meta property="article:section" content={continent} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Feeds / discovery -->
    <link rel="sitemap"  href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title="Teslou kolem světa — RSS" href="/rss.xml" />

    <!-- Schema: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Teslou kolem světa",
      "url": siteUrl,
      "sameAs": [
        "https://youtube.com/@tesloukolemsveta",
        "https://www.facebook.com/tesloukolemsveta/",
        "https://www.instagram.com/tesloukolemsveta/"
      ]
    })} />

    <!-- Extra head content (page-level schemas) -->
    <slot name="head" />

    <!-- Motion system -->
    <script>
      import '../scripts/motion.js';
    </script>
  </head>

  <body>
    <a href="#main" class="skip-link">Přeskočit na obsah</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <div class="family-banner" aria-hidden="true">
      <img
        src="/images/family-rodina-hlavni.jpeg"
        alt=""
        class="family-banner-img"
        loading="lazy"
      />
      <div class="family-banner-fade"></div>
    </div>
    <Footer />
  </body>
</html>

<style>
  .family-banner {
    position: relative;
    margin-top: -4rem;
    height: clamp(220px, 28vw, 400px);
    overflow: hidden;
    z-index: 0;
  }

  main {
    position: relative;
    z-index: 1;
  }

  .family-banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  /* Gradient nahoře — obsah plynule přechází do fotky */
  .family-banner-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      var(--bg, #fff) 0%,
      transparent 35%,
      transparent 80%,
      rgba(0,0,0,0.15) 100%
    );
    pointer-events: none;
  }
</style>
